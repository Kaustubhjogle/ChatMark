{
  "manifest_version": 3,
  "name": "ChatGPT Question Navigator",
  "description": "Shows your questions in the current ChatGPT chat and jumps to them.",
  "version": "1.0.0",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Question Navigator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

{
  "manifest_version": 3,
  "name": "ChatMark",
  "description": "Shows your questions in the currentchat and jumps to them.",
  "version": "1.0.0",

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "permissions": ["activeTab", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Question Navigator",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon128.png",
      "32": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
